# ===========================================
# Production Environment Configuration
# ===========================================
# Copy this file to .env.production and fill in the values
# for your production deployment.

# ===========================================
# Database Configuration (Required)
# ===========================================
# MySQL connection string for production
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://cmmb_user:your_secure_password@mysql:3306/cmmb"

# ===========================================
# NextAuth Configuration (Required)
# ===========================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-production-secret-key-change-this"

# Production URL (must include protocol and port if non-standard)
NEXTAUTH_URL="https://your-domain.com"

# ===========================================
# OpenClaw Gateway Integration (Optional)
# ===========================================
# Token for authenticating with OpenClaw Gateway API
# Used for instance lifecycle management (start/stop/restart)
# Leave empty if not using OpenClaw Gateway features
OPENCLAW_GATEWAY_TOKEN=""

# ===========================================
# Optional: Node Environment
# ===========================================
# NODE_ENV is typically set by the deployment platform
# NODE_ENV="production"

# ===========================================
# Optional: Logging
# ===========================================
# Log level for production (error, warn, info, debug)
# LOG_LEVEL="info"

# ===========================================
# Security Recommendations
# ===========================================
# 1. Use strong, unique passwords for DATABASE_URL
# 2. Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# 3. Use HTTPS in production (NEXTAUTH_URL should start with https://)
# 4. Never commit .env.production to version control
# 5. Use Docker secrets or environment variable injection in production