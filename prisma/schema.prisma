// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VIEWER
}

enum InstanceStatus {
  ONLINE
  OFFLINE
  STARTING
  STOPPING
  ERROR
}

enum ChannelType {
  WHATSAPP
  TELEGRAM
  DISCORD
  SIGNAL
  WECHAT
  WEIBO
  DINGTALK
  FEISHU
  WECOM
  QQBOT
  SLACK
  OTHER
}

enum ChannelStatus {
  ONLINE
  OFFLINE
  ERROR
  CONFIGURING
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances        Instance[]
  auditLogs        AuditLog[]
  workspaceBackups WorkspaceBackup[]

  @@map("users")
}

model Instance {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      InstanceStatus @default(OFFLINE)
  gatewayUrl  String
  token       String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  channels   Channel[]
  auditLogs  AuditLog[]

  @@map("instances")
}

model Channel {
  id           String        @id @default(cuid())
  name         String        @unique
  type         ChannelType   @default(OTHER)
  status       ChannelStatus @default(OFFLINE)
  enabled      Boolean       @default(true)
  accountId    String?
  config       Json?
  lastError    String?
  lastInbound  DateTime?
  lastOutbound DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  instanceId   String?
  instance     Instance?     @relation(fields: [instanceId], references: [id])

  auditLogs    AuditLog[]

  @@map("channels")
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime  @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])

  instanceId String?
  instance   Instance? @relation(fields: [instanceId], references: [id])

  channelId  String?
  channel    Channel?  @relation(fields: [channelId], references: [id])

  workspaceBackupId String?
  workspaceBackup   WorkspaceBackup? @relation(fields: [workspaceBackupId], references: [id])

  @@map("audit_logs")
}

model WorkspaceBackup {
  id          String   @id @default(cuid())
  name        String
  description String?
  filePath    String   // Path to backup archive in storage
  size        Int      // File size in bytes
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  auditLogs   AuditLog[]

  @@map("workspace_backups")
}