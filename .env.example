# ===========================================
# Development Environment Configuration
# ===========================================
# Copy this file to .env for local development

# ===========================================
# Database Configuration (Required)
# ===========================================
DATABASE_URL="mysql://cmmb_user:cmmb_password@localhost:3306/cmmb"

# ===========================================
# NextAuth Configuration (Required)
# ===========================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# OpenClaw Gateway Integration (Optional)
# ===========================================
# URL for the OpenClaw Gateway (default: http://localhost:18789)
OPENCLAW_GATEWAY_URL="http://localhost:18789"

# Token for authenticating with OpenClaw Gateway API
# Used for instance lifecycle management (start/stop/restart)
# Leave empty if not using OpenClaw Gateway features
OPENCLAW_GATEWAY_TOKEN=""

# ===========================================
# MySQL Configuration (for Docker Compose)
# ===========================================
# These are used by docker-compose.yml to configure the MySQL container
MYSQL_ROOT_PASSWORD="root_password"
MYSQL_USER="cmmb_user"
MYSQL_PASSWORD="cmmb_password"